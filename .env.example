# Node environment
NODE_ENV=production

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# JWT Authentication (use 32+ character random string)
JWT_SECRET=replace_with_32_plus_character_random_string

# Server Port
PORT=3000

# Cloudinary (Image Hosting)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Twilio (SMS OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SID=

# Resend (Email Service)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
EMAIL_FROM=LedgeStay <noreply@yourdomain.com>
APP_BASE_URL=https://ledge-stay.up.railway.app

# Google Maps (Optional)
GOOGLE_MAPS_EMBED_API_KEY=

# Notes:
# 1. Never commit .env to git (already in .gitignore)
# 2. Generate strong JWT_SECRET: use `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
# 3. Replace all placeholder values with actual credentials
# 4. For local development, you can use temporary/test API keys
# 5. Rotate credentials immediately if they're ever exposed
